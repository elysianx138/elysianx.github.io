@@ -0,0 +1,117 @@
+/* MyBlog — 功能增强样式(搜索 / 归档 / 标签 / 阅读体验) */
+
+/* === 导航搜索框 === */
+.nav-search {
+    display: flex; align-items: center; gap: 6px;
+    background: var(--bg-secondary);
+    border: 1px solid var(--border);
+    border-radius: 18px;
+    padding: 4px 12px;
+    color: var(--text-muted);
+    transition: border-color .2s;
+}
+.nav-search:focus-within { border-color: var(--accent-border); }
+.nav-search input {
+    border: none; background: transparent; outline: none;
+    color: var(--text); font-size: 13px; width: 110px;
+    transition: width .25s ease;
+}
+.nav-search input:focus { width: 160px; }
+@media (max-width: 768px) { .nav-search { display: none; } }
+
+/* === 搜索结果页表单 === */
+.search-page-form {
+    display: flex; gap: 10px; margin: 14px 0 6px;
+    max-width: 520px;
+}
+.search-page-form input {
+    flex: 1; padding: 10px 16px;
+    border: 1px solid var(--border); border-radius: var(--radius);
+    background: var(--bg-card); color: var(--text);
+    font-size: 14px; outline: none;
+}
+.search-page-form input:focus { border-color: var(--accent-border); }
+
+/* === 归档时间轴 === */
+.archive-timeline { position: relative; }
+.archive-year-block { margin-bottom: 32px; }
+.archive-year {
+    font-family: 'Noto Serif SC', Georgia, serif;
+    font-size: 28px; font-weight: 700; color: var(--text);
+    display: flex; align-items: baseline; gap: 12px;
+    margin-bottom: 6px;
+}
+.archive-year-count { font-size: 13px; font-weight: 400; color: var(--text-muted); font-family: 'Noto Sans SC', sans-serif; }
+.archive-list {
+    list-style: none;
+    border-left: 2px solid var(--border);
+    margin-left: 6px; padding-left: 0;
+}
+.archive-item {
+    display: flex; align-items: baseline; gap: 14px;
+    padding: 9px 0 9px 22px;
+    position: relative; cursor: pointer;
+}
+.archive-item::before {
+    content: ''; position: absolute; left: -5px; top: 17px;
+    width: 8px; height: 8px; border-radius: 50%;
+    background: var(--border); transition: background .2s, transform .2s;
+}
+.archive-item:hover::before { background: var(--accent); transform: scale(1.3); }
+.archive-date { font-size: 13px; color: var(--text-muted); font-variant-numeric: tabular-nums; flex-shrink: 0; }
+.archive-title { font-size: 15px; color: var(--text); }
+.archive-item:hover .archive-title { color: var(--accent); }
+.archive-tags { margin-left: auto; flex-shrink: 0; }
+.archive-tag {
+    font-size: 11px; color: var(--accent);
+    background: var(--accent-light);
+    padding: 1px 8px; border-radius: 10px; margin-left: 6px;
+}
+@media (max-width: 600px) { .archive-tags { display: none; } }
+
+/* === 标签云 === */
+.tag-cloud {
+    display: flex; flex-wrap: wrap; align-items: baseline;
+    gap: 14px 22px; padding: 28px;
+    line-height: 1.4;
+}
+.tag-cloud-item {
+    color: var(--text-secondary);
+    font-family: 'Noto Serif SC', Georgia, serif;
+    transition: color .2s;
+    text-decoration: none;
+}
+.tag-cloud-item:hover { color: var(--accent); text-decoration: none; }
+.tag-cloud-item sup { font-size: 11px; color: var(--text-muted); margin-left: 2px; }
+.tag-hash { color: var(--accent); margin-right: 4px; }
+
+/* === 阅读进度条 === */
+.read-progress {
+    position: fixed; top: 0; left: 0; height: 3px; width: 0;
+    background: var(--accent); z-index: 200;
+    transition: width .1s linear;
+}
+
+/* === 文章代码块优化 === */
+.md-body pre {
+    border-radius: var(--radius);
+    border: 1px solid var(--border);
+    overflow-x: auto;
+    margin: 16px 0;
+}
+.md-body pre code { display: block; padding: 16px; font-size: 13.5px; line-height: 1.7; }
+.md-body code:not(pre code) {
+    background: var(--accent-light); color: var(--accent);
+    padding: 2px 6px; border-radius: 4px; font-size: 0.9em;
+}
+.md-body blockquote {
+    border-left: 3px solid var(--accent);
+    background: var(--bg-secondary);
+    padding: 10px 18px; margin: 14px 0;
+    color: var(--text-secondary);
