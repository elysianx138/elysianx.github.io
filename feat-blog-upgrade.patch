+}
+.md-body img { max-width: 100%; border-radius: var(--radius); }
+.md-body table { border-collapse: collapse; width: 100%; margin: 14px 0; }
+.md-body th, .md-body td { border: 1px solid var(--border); padding: 8px 12px; font-size: 14px; }
